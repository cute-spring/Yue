# Skill Runtime Core minimal host integration environment

# Neutral runtime keys (preferred)
SKILL_RUNTIME_MODE=import_gate
SKILL_RUNTIME_API_PREFIX=/api
SKILL_RUNTIME_INCLUDE_SKILL_IMPORTS=true
SKILL_RUNTIME_INCLUDE_SKILL_GROUPS=true
SKILL_RUNTIME_WATCH_ENABLED=true
SKILL_RUNTIME_RELOAD_DEBOUNCE_MS=2000

# Optional host-specific aliases used in minimal_fastapi_host.py
HOST_RUNTIME_DATA_DIR=~/.host-app/data
HOST_RUNTIME_API_PREFIX=/api
