[
  {
    "name": "example-server",
    "transport": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "mcp-server-example"
    ],
    "enabled": false,
    "env": null
  },
  {
    "name": "company-jira",
    "transport": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "your-jira-mcp-package"
    ],
    "enabled": false,
    "env": {
      "JIRA_BASE_URL": "https://jira.company.internal",
      "JIRA_USERNAME": "alice@example.com",
      "JIRA_TOKEN": "${JIRA_TOKEN}"
    }
  }
]
