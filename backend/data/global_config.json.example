{
  "settings": {
    "request_timeout": 300,
    "meta_enabled": true,
    "meta_provider": "openai",
    "meta_model": "gpt-4o-mini",
    "meta_timeout_ms": 1800,
    "meta_max_tokens": 96,
    "meta_use_runtime_model_for_title": false
  },
  "llm": {
    "provider": "deepseek",
    "enabled_providers": "openai,deepseek,ollama",
    "openai_enabled_models_mode": "allowlist",
    "settings": {
      "request_timeout": 300,
      "meta_enabled": true,
      "meta_provider": "openai",
      "meta_model": "gpt-4o-mini",
      "meta_timeout_ms": 1800,
      "meta_max_tokens": 96,
      "meta_use_runtime_model_for_title": false
    },
    "routing": {
      "default_mode": "legacy",
      "fallback_policy": "use_legacy_agent_model",
      "auto_upgrade_enabled": true,
      "roles": {
        "general_chat": {
          "provider": "deepseek",
          "model": "deepseek-chat"
        },
        "tool_use": {
          "inherit": "general_chat"
        },
        "reasoning": {
          "inherit": "general_chat"
        }
      },
      "rules": {
        "tool_call_requires_role": "tool_use",
        "multi_skill_requires_role": "reasoning"
      }
    },
    "model_tiers": {
      "light": {
        "provider": "deepseek",
        "model": "deepseek-chat"
      },
      "balanced": {
        "provider": "deepseek",
        "model": "deepseek-chat"
      },
      "heavy": {
        "provider": "deepseek",
        "model": "deepseek-reasoner"
      }
    },
    "providers": {
      "openai": {
        "default_model": "gpt-4o",
        "max_output_tokens": 8192,
        "enabled_models": [
          "openai/gpt-4o",
          "openai/gpt-4o-mini"
        ],
        "api_key": "YOUR_OPENAI_API_KEY"
      },
      "deepseek": {
        "default_model": "deepseek-chat",
        "max_output_tokens": 8192,
        "api_key": "YOUR_DEEPSEEK_API_KEY"
      },
      "ollama": {
        "default_model": "deepseek-r1:1.5b",
        "base_url": "http://localhost:11434",
        "max_output_tokens": 8192
      }
    },
    "models": {
      "openai/gpt-4o": {
        "display_name": "GPT-4o",
        "description": "General multimodal model for text and image understanding",
        "context_window": 128000,
        "max_output_tokens": 8192,
        "capabilities": [
          "text",
          "vision",
          "function_calling"
        ],
        "enabled": true
      },
      "openai/gpt-4o-mini": {
        "display_name": "GPT-4o Mini",
        "description": "Lower-cost multimodal model for text and image understanding",
        "context_window": 128000,
        "max_output_tokens": 4096,
        "capabilities": [
          "text",
          "vision",
          "function_calling"
        ],
        "enabled": true
      },
      "deepseek/deepseek-chat": {
        "display_name": "DeepSeek Chat",
        "description": "Text-only model optimized for general chat and tool calling",
        "context_window": 128000,
        "max_output_tokens": 8192,
        "capabilities": [
          "text",
          "function_calling"
        ],
        "enabled": true
      }
    },
    "custom_models": []
  },
  "doc_access": {
    "allow_roots": [
      "."
    ]
  },
  "preferences": {
    "theme": "light",
    "language": "en",
    "default_agent": "default",
    "voice_input_enabled": true,
    "voice_input_provider": "browser",
    "voice_input_language": "auto",
    "voice_input_show_interim": true
  },
  "tool_call_mismatch": {
    "auto_retry_enabled": true,
    "fallback_model": "gpt-4o-mini"
  },
  "skills_directory_strategy": {
    "builtin_dir": "backend/data/skills",
    "workspace_dir": "data/skills",
    "user_dir": "~/.yue/skills",
    "watch_enabled": true,
    "reload_debounce_ms": 2000
  }
}
