{
  "settings": {
    "request_timeout": 300,
    "meta_enabled": true,
    "meta_provider": "openai",
    "meta_model": "gpt-4o-mini",
    "meta_timeout_ms": 1800,
    "meta_max_tokens": 96,
    "meta_use_runtime_model_for_title": false
  },
  "llm": {
    "provider": "deepseek",
    "enabled_providers": "openai,azure_openai,deepseek,ollama,zhipu",
    "openai_enabled_models_mode": "allowlist",
    "zhipu_enabled_models_mode": "allowlist",
    "settings": {
      "request_timeout": 300,
      "meta_enabled": true,
      "meta_provider": "openai",
      "meta_model": "gpt-4o-mini",
      "meta_timeout_ms": 1800,
      "meta_max_tokens": 96,
      "meta_use_runtime_model_for_title": false
    },
    "providers": {
      "openai": {
        "default_model": "gpt-4o",
        "max_output_tokens": 8192,
        "enabled_models": [
          "openai/gpt-4o",
          "openai/gpt-4o-mini"
        ],
        "api_key": "YOUR_OPENAI_API_KEY"
      },
      "zhipu": {
        "default_model": "glm-4.6v",
        "base_url": "https://open.bigmodel.cn/api/paas/v4/",
        "max_output_tokens": 4096,
        "enabled_models": [
          "zhipu/glm-4.6v"
        ],
        "api_key": "YOUR_ZHIPU_API_KEY"
      },
      "deepseek": {
        "default_model": "deepseek-chat",
        "max_output_tokens": 8192,
        "api_key": "YOUR_DEEPSEEK_API_KEY"
      },
      "ollama": {
        "default_model": "deepseek-r1:1.5b",
        "base_url": "http://localhost:11434",
        "max_output_tokens": 8192
      },
      "azure_openai": {
        "default_model": "gpt4o",
        "endpoint": "https://your-resource.openai.azure.com",
        "api_version": "2024-06-01",
        "max_output_tokens": 8192,
        "api_key": "YOUR_AZURE_API_KEY"
      }
    },
    "models": {
      "openai/gpt-4o": {
        "display_name": "GPT-4o",
        "description": "General multimodal model for text and image understanding",
        "context_window": 128000,
        "max_output_tokens": 8192,
        "capabilities": [
          "text",
          "vision",
          "function_calling"
        ],
        "enabled": true
      },
      "openai/gpt-4o-mini": {
        "display_name": "GPT-4o Mini",
        "description": "Lower-cost multimodal model for text and image understanding",
        "context_window": 128000,
        "max_output_tokens": 4096,
        "capabilities": [
          "text",
          "vision",
          "function_calling"
        ],
        "enabled": true
      },
      "zhipu/glm-4.6v": {
        "display_name": "GLM-4.6V",
        "description": "Vision-capable model example with text + image input",
        "context_window": 128000,
        "max_output_tokens": 4096,
        "capabilities": [
          "text",
          "vision"
        ],
        "enabled": true
      },
      "deepseek/deepseek-chat": {
        "display_name": "DeepSeek Chat",
        "description": "Text-only model optimized for general chat and tool calling",
        "context_window": 128000,
        "max_output_tokens": 8192,
        "capabilities": [
          "text",
          "function_calling"
        ],
        "enabled": true
      }
    },
    "custom_models": []
  },
  "doc_access": {
    "allow_roots": [
      "."
    ]
  },
  "preferences": {
    "theme": "light",
    "language": "en",
    "default_agent": "default",
    "voice_input_enabled": true,
    "voice_input_provider": "browser",
    "voice_input_language": "auto",
    "voice_input_show_interim": true
  },
  "tool_call_mismatch": {
    "auto_retry_enabled": true,
    "fallback_model": "gpt-4o-mini"
  },
  "skills_directory_strategy": {
    "builtin_dir": "backend/data/skills",
    "workspace_dir": "data/skills",
    "user_dir": "~/.yue/skills",
    "watch_enabled": true,
    "reload_debounce_ms": 2000
  }
}
