# LLM API Keys
OPENAI_API_KEY=your_openai_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
ZHIPU_API_KEY=your_zhipu_api_key
GEMINI_API_KEY=your_gemini_api_key
LITELLM_API_KEY=your_litellm_api_key
LLM_API_KEY=your_generic_llm_api_key

# LLM Base URLs
OPENAI_BASE_URL=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GEMINI_BASE_URL=
OLLAMA_BASE_URL=http://localhost:11434
LITELLM_BASE_URL=
LLM_BASE_URL=

# LLM Models
OPENAI_MODEL=gpt-4o
DEEPSEEK_MODEL=deepseek-chat
OLLAMA_MODEL=llama3
GEMINI_MODEL=gemini-1.5-pro
ZHIPU_MODEL=glm-4v
LITELLM_MODEL=
LLM_MODEL_NAME=

# OpenRouter Sample (OpenAI-compatible)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=your_openrouter_api_key
# OPENAI_MODEL=stepfun/step-3.5-flash
# LLM_PROVIDER=openai
# ENABLED_PROVIDERS=openai,azure_openai,deepseek,ollama

# Azure OpenAI Configuration
# Base URL should be the endpoint like https://your-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com

# Deployment configuration:
# 1. Single deployment: gpt-4o
# 2. Multiple deployments: gpt-4o,gpt-35-turbo
# 3. Per-deployment versions: gpt-4o:2024-06-01,o1-preview:2024-09-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o:2024-06-01,o1-preview:2024-09-01-preview
AZURE_OPENAI_API_VERSION=2024-06-01

# Authentication (choose one):
# Option A: API Key
AZURE_OPENAI_TOKEN=your_azure_api_key

# Option B: Azure AD Credentials
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# LLM Configuration
LLM_PROVIDER=deepseek # openai, deepseek, zhipu, ollama, gemini, litellm
# Control which providers are visible in the UI (comma-separated)
# Options: openai, azure_openai, deepseek, ollama, gemini, zhipu, litellm, custom
ENABLED_PROVIDERS=openai,azure_openai,deepseek,ollama
LLM_REQUEST_TIMEOUT=60
LOG_LEVEL=INFO

# LLM Request/Response Verbose Logging
# true: print detailed request/response payloads to backend.log
# false: disable detailed payload logging
LLM_VERBOSE_LOG_ENABLED=true
# Max chars per logged text field (message/system_prompt/response/error)
LLM_LOG_MAX_CHARS=120000
# Whether to log raw image data payloads (base64). Recommended false in production.
LLM_LOG_INCLUDE_IMAGE_DATA=false

# Tool-call mismatch auto-retry
# true: when finish_reason=tool_call but no tool events, auto retry once with fallback model
# false: skip auto retry and directly return mismatch prompt
TOOL_CALL_MISMATCH_AUTO_RETRY_ENABLED=true
# Fallback model used by tool-call mismatch auto-retry
TOOL_CALL_MISMATCH_FALLBACK_MODEL=gpt-4o-mini

# Docs Access Scope (Optional)
# Takes precedence over config file doc_access.allow_roots / deny_roots.
# Supported formats:
# 1) Comma-separated: /path/a,/path/b
# 2) JSON array: ["/path/a","/path/b"]
DOC_ACCESS_ALLOW_ROOTS=/path/to/project/docs,/path/to/knowledge-base
DOC_ACCESS_DENY_ROOTS=["/System","/Library","/private"]
# Inject effective scope summary into system prompt (default: true)
PROMPT_SCOPE_SUMMARY_ENABLED=true
# Reveal full absolute paths in prompt scope summary (default: false, recommended to keep false)
PROMPT_SCOPE_SUMMARY_REVEAL_PATHS=false
# Max roots displayed in prompt summary
PROMPT_SCOPE_SUMMARY_MAX_ROOTS=3

# MCP Tools Configuration
AMAP_MAPS_API_KEY=your_amap_api_key
OPENWEATHER_API_KEY=your_openweather_api_key
WEREAD_COOKIE=your_weread_cookie

# Proxy & Network Configuration (Optional)
# LLM_PROXY_URL=http://your-proxy:port
# NO_PROXY=localhost,127.0.0.1
# SSL_CERT_FILE=
