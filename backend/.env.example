# ===================================================================
# Runtime selection and global behavior
# Used by: app/services/config_service.py#get_llm_config, app/observability.py
# ===================================================================
# Default provider used when request does not explicitly set provider/model
LLM_PROVIDER=deepseek
# Controls provider tabs/options visible in UI
# Options: openai, azure_openai, deepseek, ollama, gemini, zhipu, litellm, custom
ENABLED_PROVIDERS=openai,azure_openai,deepseek,ollama
# Global timeout (seconds) for model requests
LLM_REQUEST_TIMEOUT=60
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ===================================================================
# Provider credentials and model endpoints
# Used by: app/services/llm/config_strategies.py and provider implementations
# Configure only providers you actually use.
# ===================================================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-4v

GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

LITELLM_API_KEY=your_litellm_api_key
LITELLM_BASE_URL=
LITELLM_MODEL=

# Azure auth: use token OR tenant/client/client_secret flow
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o:2024-06-01,o1-preview:2024-09-01-preview
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_TOKEN=your_azure_api_key
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# OpenRouter sample (OpenAI-compatible)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=your_openrouter_api_key
# OPENAI_MODEL=stepfun/step-3.5-flash
# LLM_PROVIDER=openai
# ENABLED_PROVIDERS=openai,azure_openai,deepseek,ollama

# ===================================================================
# Request/response verbose logging controls
# Used by: app/api/chat.py
# ===================================================================
LLM_VERBOSE_LOG_ENABLED=true
LLM_LOG_MAX_CHARS=120000
LLM_LOG_INCLUDE_IMAGE_DATA=false

# ===================================================================
# Tool-call mismatch fallback controls
# Used by: app/services/config_service.py#get_tool_call_mismatch_config
# ===================================================================
TOOL_CALL_MISMATCH_AUTO_RETRY_ENABLED=true
TOOL_CALL_MISMATCH_FALLBACK_MODEL=gpt-4o-mini
# Optional candidate list (comma-separated). If set, first one becomes fallback_model.
# TOOL_CALL_MISMATCH_FALLBACK_MODELS=gpt-4o-mini,openai/gpt-4o-mini,deepseek/deepseek-chat

# ===================================================================
# Document access scope and prompt scope summary
# Used by: app/services/config_service.py#get_doc_access, app/api/chat.py
# ===================================================================
# Takes precedence over config file doc_access.allow_roots / deny_roots.
# Supported formats:
# 1) Comma-separated: /path/a,/path/b
# 2) JSON array: ["/path/a","/path/b"]
DOC_ACCESS_ALLOW_ROOTS=/path/to/project/docs,/path/to/knowledge-base
DOC_ACCESS_DENY_ROOTS=["/System","/Library","/private"]
# Inject effective scope summary into system prompt (default: true)
PROMPT_SCOPE_SUMMARY_ENABLED=true
# Reveal absolute paths in prompt summary (default: false)
PROMPT_SCOPE_SUMMARY_REVEAL_PATHS=false
# Max roots displayed in prompt summary
PROMPT_SCOPE_SUMMARY_MAX_ROOTS=3

# ===================================================================
# Optional network/proxy settings
# Used by: app/services/llm/utils.py and app/mcp/manager.py
# ===================================================================
# LLM_PROXY_URL=http://your-proxy:port
# NO_PROXY=localhost,127.0.0.1
# SSL_CERT_FILE=
